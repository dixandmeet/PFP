DATABASE_URL="postgresql://user:pass@localhost:5432/profoot"

# Auth.js v5 — secret pour signer les JWT et chiffrer les cookies
# Générer avec: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-change-in-production"

# URL de l'app (optionnel en v5, détecté automatiquement sur Vercel)
AUTH_URL="http://localhost:3000"

# URL publique canonique de l'application (utilisée dans les emails, liens, etc.)
# En production, mettre votre domaine réel (ex: https://profootprofile.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio123"
S3_BUCKET="profoot-files"
S3_REGION="us-east-1"
# USE_LOCAL_STORAGE="true" — pour stocker les fichiers en local (public/uploads) sans MinIO

OPENAI_API_KEY="sk-..."

# ============================================
# Football APIs - Aggregator Service
# ============================================

# API-Football (api-sports.io)
# Plan gratuit: 100 requêtes/jour
# Inscription: https://www.api-football.com/
# Utilisé pour: Scores en direct uniquement
API_FOOTBALL_KEY="your-api-football-key-here"

# Football-Data.org
# Plan gratuit: 10 requêtes/minute
# Inscription: https://www.football-data.org/client/register
# Utilisé pour: Calendriers et classements
FOOTBALL_DATA_API_KEY="your-football-data-api-key-here"

# TheSportsDB
# Clé gratuite par défaut: "3" (illimité pour usage personnel)
# Documentation: https://www.thesportsdb.com/api.php
# Utilisé pour: Assets (logos, images stades, bannières)
THESPORTSDB_API_KEY="3"

# Email avec Resend (https://resend.com)
# Créez un compte gratuit sur resend.com pour obtenir une clé API
RESEND_API_KEY="re_your-resend-api-key-here"
EMAIL_FROM="Profoot Profile <contact@profootprofile.com>"

# Google OAuth (https://console.cloud.google.com)
# 1. Créez un projet sur Google Cloud Console
# 2. Activez l'API Google+ et l'API OAuth
# 3. Créez des identifiants OAuth 2.0
# 4. Ajoutez http://localhost:3000/api/auth/callback/google aux URIs de redirection
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optionnel: Redis pour rate limiting
RATE_LIMIT_REDIS_URL="redis://localhost:6379"

# ============================================
# Stripe - Paiements & Crédits
# ============================================

# Clés API Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret (stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs des plans d'abonnement (à créer dans Stripe Dashboard > Products)
STRIPE_PRICE_STARTER="price_starter_id"
STRIPE_PRICE_GROWTH="price_growth_id"
STRIPE_PRICE_PRO="price_pro_id"
STRIPE_PRICE_ELITE="price_elite_id"

# Secret pour sécuriser les endpoints cron
CRON_SECRET="your-cron-secret-here"
